{
	"name": "recito",
	"version": "1.0.0",
	"description": "Obsidian plugin that reads notes aloud with karaoke-style word highlighting. Supports OpenAI, ElevenLabs, Groq, Mimo, and custom TTS providers.",
	"main": "main.js",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/allgemeiner-intellekt/Recito-in-Obsidian.git"
	},
	"bugs": {
		"url": "https://github.com/allgemeiner-intellekt/Recito-in-Obsidian/issues"
	},
	"homepage": "https://github.com/allgemeiner-intellekt/Recito-in-Obsidian#readme",
	"author": "allgemeiner-intellekt",
	"license": "0BSD",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"config": {
		"tag-version-prefix": ""
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"tts",
		"text-to-speech",
		"read-aloud"
	],
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.39",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^1.6.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
